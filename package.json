{
    "scripts": {
        "icons": "bash scripts/render-icons.sh",
        "build": "npm run icons && rollup -c",
        "watch": "npm run icons && rollup -c -w --watch.onEnd=\"streamdeck restart com.waleed-salama.turn-off-displays\"",
        "validate": "streamdeck validate com.waleed-salama.turn-off-displays.sdPlugin",
        "pack": "streamdeck pack com.waleed-salama.turn-off-displays.sdPlugin"
    },
    "type": "module",
    "devDependencies": {
        "@elgato/cli": "^1.7.3",
        "@rollup/plugin-commonjs": "^28.0.0",
        "@rollup/plugin-node-resolve": "^15.2.2",
        "@rollup/plugin-terser": "^0.4.4",
        "@rollup/plugin-typescript": "^12.1.0",
        "@tsconfig/node20": "^20.1.2",
        "@types/node": "~20.15.0",
        "lucide-static": "^0.577.0",
        "rollup": "^4.0.2",
        "tslib": "^2.6.2",
        "typescript": "^5.2.2"
    },
    "dependencies": {
        "@elgato/streamdeck": "^2.0.0"
    }
}
